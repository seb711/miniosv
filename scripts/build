#!/usr/bin/env bash
# Build the slim OSv kernel.
#
# The application is statically linked into the kernel (app/ by default, or
# test/ via "app=tests"), and the kernel is booted directly via QEMU -kernel
# (PVH) with no disk: there is no filesystem, no modules, and no data image.
# This script just drives make. Run the result with scripts/run.py.
#
# Usage:
#   scripts/build [make-args]          # build
#   scripts/build clean                # clean
#
# fs=/image=/modules=/usrskel= are accepted but ignored (kept for compatibility
# with old invocations); the app is in-kernel and there is no image to build.

set -e
trap 'echo "$0 failed: $BASH_COMMAND" >&2; exit $?' ERR

usage() { sed -n '2,15p' "$0"; exit "${1:-0}"; }

# If "MAKEFLAGS" is set we were invoked from "make"; strip image=/modules= so the
# nested make below does not loop back into us.
MAKEFLAGS=${MAKEFLAGS/ image=/ zzz=}
MAKEFLAGS=${MAKEFLAGS/#image=/zzz=}
MAKEFLAGS=${MAKEFLAGS/ modules=/ zzz=}
MAKEFLAGS=${MAKEFLAGS/#modules=/zzz=}
unset image modules

# Forward every arg to make except the build-only keys we interpret here.
declare -a args
do_clean=
for i in "$@"; do
	case $i in
	--help|-h)        usage ;;
	clean)            do_clean=yes ;;
	fs=*|image=*|modules=*|usrskel=*) ;;   # app is in-kernel, no image; ignored
	arch=*)           eval "$i"; args+=("$i") ;;
	*)                args+=("$i") ;;
	esac
done

if [[ "${arch-}" == "aarch64" && -d "build/downloaded_packages/aarch64/toolchain/" ]]; then
	. scripts/download_aarch64_toolchain.sh
	export CROSS_PREFIX=aarch64-none-linux-gnu-
fi

if [ -n "$do_clean" ]; then
	make "${args[@]}" clean
	exit
fi

# Build the kernel. The command line is empty (the in-kernel app runs via
# osv_app_main()); run.py passes it via QEMU -append at boot if needed.
make "${args[@]}" | tee build.out
test "${PIPESTATUS[0]}" -eq 0 || { echo "make failed" >&2; exit 1; }
test -f build/last/loader-stripped.elf || { echo "'make' did not leave expected results" >&2; exit 2; }
